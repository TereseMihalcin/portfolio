---
import '../styles/global.css';
import Project from '../components/project.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/me.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Terese Mihalcin Professional Portfolio</title>

		<!-- Bootstrap 5 -->
		<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
		
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

	</head>
	<body class="">
		<div class="container mt-3">
			<div class="row justify-content-left mb-2">
				<div class="col-6 offset-1">
					<span class="devicon devicon--php"></span>
					<span class="devicon devicon--linux"></span>
					<span class="devicon devicon--git"></span>
					<span class="devicon devicon--apache"></span>
					<span class="devicon devicon--html5"></span>
					<span class="devicon devicon--css3"></span>
					<span class="devicon devicon--javascript"></span>
				</div>
				<div class="col-4 text-end">
					<a href="#" data-tooltip="Change theme" data-flow="right"><div class='dinkie-icons--black-sun-with-rays' id="theme-toggle"></div></a>
				</div>
			</div>
			<div class="row">
				<div class="col-10 offset-1 clearfix">
					<img src="/real-me.jpg" alt="Picture of Terese Mihalcin in an apple orchard" id="pfp" class="col-md-6 float-md-end mt-1 mb-3 ms-md-3">
					<h1>Terese Mihalcin</h1>
					<label>Software Developer, Web Enthusiast</label>
					<p>Hi there, I'm a software developer, working at a small company, building websites and software applications for newspapers and media companies. I am passionate about learning modern development strategies, and building new projects in my free time.ヾ(^ ^ゞ</p>	
				</div>

			</div>
			<div class="row justify-content-center">
				<div class="col-10">
					<label class="mb-1">Projects</label>
					<div class="d-flex gap-4 flex-nowrap expander-container">
					<Project />
					</div>
				</div>
			</div>
			<div class="row justify-content-left mt-3">
				<div class="col-11 offset-1">
					<a href="https://www.linkedin.com/in/teresemihalcin" target="_blank" data-tooltip="Visit my LinkedIn!" data-flow="down"><span class="streamline-pixel--logo-linkedin"></span></a>
					<a href="https://github.com/teresemihalcin" target="_blank" data-tooltip="See my GitHub projects!" data-flow="down"><span class="pixel--github"></span></a>
					<a href="https://blog.teresemihalcin.com" target="_blank" data-tooltip="Get to know me more at my blog!" data-flow="down"><span class="streamline-pixel--internet-network-www"></span></a>
					<a href="https://blento.app/mihalc.in" target="_blank" data-tooltip="Check out my blento Portfolio" data-flow="down"><span class="streamline-pixel--food-drink-bread"></span></a>	
				</div>
			</div>
		</div>
		
	</body>

	<style>

		@import url('https://fonts.googleapis.com/css2?family=Barrio&display=swap');
		@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap');
		@import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');
		@import url('https://fonts.googleapis.com/css2?family=Geo:ital@0;1&display=swap');
		
		:root {
			--accent: #cf5211;
			--less-light: #b2d581;
			--light: #d7e9be;
			--less-dark: #3a4658;
			--dark: #262b33;
		}
		body.light {
            background-color: var(--light);
            color: var(--dark);

			.card {
				border-radius: 1rem;
				padding: 1rem;
				background: var(--less-light);
				border: 0px;
				width: 100%;
				height: 90px;
				cursor: nesw-resize;
			}
			@media screen and (max-width: 990px) {
				.expander-container {
					flex-wrap: wrap !important;
				}
			}
			@media screen and (max-width: 1199px) {
				div.card-expanded {
					overflow: auto;
				}
			}

			.card-expanded {
				border-radius: 1rem;
				padding: 1rem;
				background: var(--less-light);
				border: 0px;
				width: 300%;
				height: 300px;
				margin-top: 0;
				cursor: nesw-resize;
				min-width: 0;
				overflow: hidden;
			}
			img {
				border: 15px solid var(--less-light);
			}
			p.desc {
				background: #c1dd9a;
				border-radius: 1rem;
			}
        }
        body.dark {
            background-color: var(--dark);
            color: var(--less-light);

			.card {
				border-radius: 1rem;
				padding: 1rem;
				background: var(--less-dark);
				border: 0px;
				width:100%;
				height: 90px;
				cursor: nesw-resize;
			}
			@media screen and (max-width: 990px) {
				.expander-container {
					flex-wrap: wrap !important;
				}
			}
			@media screen and (max-width: 1199px) {
				div.card-expanded {
					overflow: auto;
				}
			}

			.card-expanded {
				border-radius: 1rem;
				padding: 1rem;
				background: var(--less-dark);
				border: 0px;
				width:300%;
				height: 300px;
				margin-top: 0;
				cursor: nesw-resize;
				min-width: 0;
				overflow: hidden;
			}
			img {
				border: 15px solid var(--less-dark);
			}
			p.desc {
				background: #323d4d;
				border-radius: 1rem;
			}
        }

		

	</style>
	<script type="text/javascript">

		const toggleButton = document.getElementById('theme-toggle');
		const body = document.body;
		const cards = document.getElementsByClassName('project');
		const img = document.getElementById('pfp');
		const desc = document.getElementsByClassName('desc');
		

		body.classList.add('dark');

		toggleButton.addEventListener('click', () => {

			// add transition class to elements, switch dark/light
			body.classList.add("transition");
			img.classList.add("transition");
			for(let i = 0; i < cards.length; i++) {
				console.log(cards[i]);
				cards[i].classList.add("transition");
			}
			for(let i = 0; i < desc.length; i++) {
				desc[i].classList.add("transition");
			}
			// change icon
			if (body.classList.contains('light')) {
				body.classList.replace('light', 'dark');
				toggleButton.classList.replace('dinkie-icons--crescent-moon', 'dinkie-icons--black-sun-with-rays');
			} else {
				body.classList.replace('dark', 'light');
				toggleButton.classList.replace('dinkie-icons--black-sun-with-rays', 'dinkie-icons--crescent-moon');
			}
		});

		// Card Expander Function
		function expand(content,heading) {

			const cards = document.getElementsByClassName('project');
			const desc = document.getElementsByClassName('desc');

			for(let i = 0; i < cards.length; i++) {
				console.log(cards[i]);
				cards[i].classList.add("transition");
			}
			for(let i = 0; i < desc.length; i++) {
				desc[i].classList.add("transition");
			}
		
			var expandContent = document.getElementById(content);
			if (expandContent.className.includes('expander-visible') != true){

				// open on click
				expandContent.classList.add('expander-visible');
				expandContent.classList.remove('expander-invisible');

				// close other open card
				var allExpandables = document.getElementsByClassName('info');

				for (var i = 0; i < allExpandables.length; i++) {
					if(expandContent === allExpandables[i]) {
						// do nothing
					} else {
						allExpandables[i].classList.add('expander-invisible');
						allExpandables[i].classList.remove('expander-visible');
					}
					
				}
			} else {
				// close on click
				expandContent.classList.add('expander-invisible');
				expandContent.classList.remove('expander-visible');
			}
		
			var expandHeading = document.getElementById(heading);
			if (expandHeading.className.includes('card-expanded') != true){

				// open on click
				expandHeading.classList.add('card-expanded'); //Show Div
				expandHeading.classList.remove('card');

				// close other open cards
				var allExpandables = document.getElementsByClassName('project');

				for (var i = 0; i < allExpandables.length; i++) {
					if(expandHeading === allExpandables[i]) {
						// do nothing
					} else {
						allExpandables[i].classList.add('card');
						allExpandables[i].classList.remove('card-expanded'); 
					}
				}
			} else {
				expandHeading.classList.add('card'); //Hide Div
				expandHeading.classList.remove('card-expanded');
			}
		}
	</script>
</html>
